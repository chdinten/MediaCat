# MediaCat environment configuration (docker-compose level).
# Copy to .env and edit. Never commit .env.
#
# Everything here is *non-secret orchestration* (paths, ports, feature flags).
# True secrets (DB passwords, API keys) live in Docker secrets under
# ${MEDIACAT_DATA_ROOT}/secrets/ or in an OS secret manager.

# ---- Project identity ----
COMPOSE_PROJECT_NAME=mediacat
MEDIACAT_ENV=dev                      # dev | staging | prod
TZ=Europe/Zurich

# ---- Host data root (MUST be outside the repo) ----
MEDIACAT_DATA_ROOT=/srv/mediacat

# ---- Networking / ports ----
# Bind to loopback by default; the reverse proxy (Caddy/Traefik) is the only
# thing exposed on a public interface.
HTTP_BIND=127.0.0.1:8080
HTTPS_BIND=127.0.0.1:8443
POSTGRES_BIND=127.0.0.1:5432
MINIO_API_BIND=127.0.0.1:9000
MINIO_CONSOLE_BIND=127.0.0.1:9001
REDIS_BIND=127.0.0.1:6379

# ---- Image tags (pin in prod) ----
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:RELEASE.2024-12-13T22-19-12Z
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine
APP_IMAGE_TAG=dev

# ---- Postgres ----
POSTGRES_DB=mediacat
POSTGRES_USER=mediacat_app
# POSTGRES_PASSWORD is NOT set here -- it is read from a docker secret.

# ---- MinIO ----
MINIO_ROOT_USER=mediacat_admin
# MINIO_ROOT_PASSWORD is NOT set here -- it is read from a docker secret.
MINIO_BUCKET_MEDIA=media-originals
MINIO_BUCKET_OCR=ocr-artifacts
MINIO_BUCKET_BACKUPS=backups

# ---- Redis ----
# REDIS_PASSWORD is read from a docker secret.

# ---- Public-facing hostnames (for Caddy / CSRF origin) ----
PUBLIC_HOSTNAME=mediacat.localhost
PUBLIC_SCHEME=https

# ---- Dev admin user (MEDIACAT_ENV=dev only; ignored in production) ----
MEDIACAT_DEV_ADMIN_PASSWORD=changeme123   # username is always "admin"

# ---- Feature flags (consumed by the app) ----
MEDIACAT_FEATURE_VISION_LOCAL=1
MEDIACAT_FEATURE_LLM_LOCAL=1
MEDIACAT_FEATURE_API_FALLBACK=1

# ---- Ollama (optional; activate with: make ollama-up or MEDIACAT_OLLAMA=1) ----
# MEDIACAT_OLLAMA=0               # set to 1 to include the ollama profile
# MEDIACAT_OLLAMA_GPU=0           # set to 1 to also load the GPU override file
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_BIND=127.0.0.1:11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_CONTEXT_LENGTH=8192        # 8 K tokens frees ~1-2 GB KV-cache VRAM; raise to 16384 if headroom allows
OLLAMA_VLM_MODEL=qwen2.5vl:32b   # ~21 GB Q4_K_M; fits in 24 GB VRAM (RTX 4090) — full GPU inference
OLLAMA_OCR_MODEL=glm-ocr          # ~2.2 GB; fits easily in VRAM

# ---- NVIDIA CUDA tuning (GPU hosts; loaded via docker-compose.gpu.yaml) ----
# OLLAMA_NUM_GPU=-1               # -1 = auto (all layers on GPU when VRAM allows; default for 4090)
# OLLAMA_FLASH_ATTENTION=1        # Flash Attention 2 — reduces KV-cache VRAM use (Ada/sm_89 supported)

# ---- Open WebUI (bundled with the ollama profile) ----
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
WEBUI_BIND=127.0.0.1:3000
WEBUI_AUTH=true                   # set to false to disable login for local-only dev
